✨ Service Code
<?php

namespace App\Services;

use App\Models\User;

class UserProfileService
{
    public function update(User $user, array $data): User
    {
        $oldEmail = $user->email;

        $user->fill($data);

        // Business rule: if email changes → reset verification
        if ($user->isDirty('email') && $oldEmail !== ($data['email'] ?? null)) {
            $user->email_verified_at = null;
        }

        $user->save();

        return $user;
    }
}
