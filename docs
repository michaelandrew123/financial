public function up(): void
{
    Schema::table('companies', function (Blueprint $table) {
        $table->decimal('gross_salary', 12, 2)->after('email');

        $table->enum('frequency', [
            'weekly',
            'biweekly',
            'monthly',
        ])->default('monthly')->after('gross_salary');

        $table->date('effective_date')->after('frequency');
    });
}

